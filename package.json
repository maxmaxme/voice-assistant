{
  "name": "voice-assistant",
  "version": "0.1.0",
  "description": "Voice assistant for smart home control via Home Assistant MCP",
  "author": "Maxim Lepekha <lepekha11@gmail.com>",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:shell": "bats tests/update.bats",
    "mcp:call": "node src/cli/mcp-call.ts",
    "chat": "AGENT_MODE=chat node src/cli/unified.ts",
    "voice": "AGENT_MODE=voice node src/cli/unified.ts",
    "http": "AGENT_MODE=http node src/cli/unified.ts",
    "start": "node src/cli/unified.ts",
    "start:wake": "AGENT_MODE=wake node src/cli/unified.ts",
    "start:both": "AGENT_MODE=both node src/cli/unified.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky || true"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@elevenlabs/elevenlabs-js": "^2.44.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.9.0",
    "cron-parser": "^5.5.0",
    "dotenv": "^17.4.2",
    "h3": "^2.0.1-rc.21",
    "mic": "^2.1.2",
    "openai": "^6.34.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "telegraf": "^4.16.3",
    "telegramify-markdown": "^1.3.3",
    "zod": "^4.3.6"
  }
}
