# Reverse proxy in front of Netdata and Dozzle. Both backends sit on the
# internal `monitoring` docker network and have no host ports of their own —
# Caddy is the only externally reachable entry point.
#
# Auth is delegated to tinyauth (forward_auth). tinyauth serves the actual
# login page and validates the session cookie; Caddy just forwards each
# request to /api/auth/caddy and either lets it through or redirects the
# browser to tinyauth's login UI.

{
	# No automatic HTTPS — listening on plain HTTP only. If you ever want
	# TLS, terminate it on a real reverse proxy in front of this one.
	auto_https off
	admin off
}

(tinyauth_forwarder) {
	forward_auth tinyauth:3000 {
		uri /api/auth/caddy
	}
}

# Netdata UI
:19999 {
	import tinyauth_forwarder
	reverse_proxy netdata:19999
}

# Dozzle UI (docker logs viewer)
:8888 {
	import tinyauth_forwarder
	reverse_proxy dozzle:8080
}
