# Home Assistant MCP
HA_URL=http://localhost:8123
HA_TOKEN=replace_with_long_lived_access_token

# OpenAI
OPENAI_API_KEY=sk-replace-me
OPENAI_MODEL=gpt-5.4-nano

# Memory
MEMORY_DB_PATH=data/assistant.db

# Server timezone — used when the agent calls `schedule_action(goal,
# schedule_kind, schedule_expr)` with a wall-clock once-time or a cron
# expression, and when displaying times back to the user. Set this to
# YOUR local timezone (IANA name) so scheduled actions fire and display correctly.
# Examples: Europe/Madrid, Europe/Moscow, America/Los_Angeles.
# Defaults to the system timezone if unset (UTC inside docker).
TZ=Europe/Madrid

# Telegram (required). The agent has a `send_to_telegram` tool that
# delivers messages to the user via this bot.
# Token from @BotFather; chat_id from @userinfobot or the bot's getUpdates.
TELEGRAM_BOT_TOKEN=replace_with_bot_token
TELEGRAM_CHAT_ID=replace_with_chat_id

# Wake-word (openWakeWord via Python subprocess)
WAKE_WORD_PYTHON=.venv/bin/python
WAKE_WORD_SCRIPT=scripts/wake_word_daemon.py
# Built-in keyword name (hey_jarvis, alexa, hey_mycroft, hey_rhasspy, ok_nabu,
# weatherman, timer) OR a path to a custom .onnx model trained via
# openWakeWord (e.g. models/alisa.onnx).
WAKE_WORD_KEYWORD=hey_jarvis
WAKE_WORD_THRESHOLD=0.5
# Set WAKE_WORD_DEBUG=1 to print per-frame max score and RMS to stderr.
# WAKE_WORD_DEBUG=1
# Set WAKE_WORD_FOLLOWUP=1 to keep listening after the assistant speaks
# (no second wake word needed). DEFAULT OFF: speaker echo into the mic
# otherwise causes the assistant to converse with itself. Enable only
# with headphones or strong acoustic isolation between speaker and mic.
# WAKE_WORD_FOLLOWUP=1

# Optional: enable OpenAI's hosted `web_search` tool. When 1, the agent can
# answer "what's the weather in Madrid", "latest news", etc. without a
# dedicated integration. Costs OpenAI tokens per call — leave off if you
# only have HA-backed queries.
# OPENAI_WEB_SEARCH=1
