# Home Assistant MCP
HA_URL=http://localhost:8123
HA_TOKEN=replace_with_long_lived_access_token

# OpenAI
OPENAI_API_KEY=sk-replace-me
OPENAI_MODEL=gpt-4o

# Memory
MEMORY_DB_PATH=data/assistant.db

# Wake-word (openWakeWord via Python subprocess)
WAKE_WORD_PYTHON=.venv/bin/python
WAKE_WORD_SCRIPT=scripts/wake_word_daemon.py
# Built-in keyword name (hey_jarvis, alexa, hey_mycroft, hey_rhasspy, ok_nabu,
# weatherman, timer) OR a path to a custom .onnx model trained via
# openWakeWord (e.g. models/alisa.onnx).
WAKE_WORD_KEYWORD=hey_jarvis
WAKE_WORD_THRESHOLD=0.5
# Set WAKE_WORD_DEBUG=1 to print per-frame max score and RMS to stderr.
# WAKE_WORD_DEBUG=1
# Set WAKE_WORD_FOLLOWUP=1 to keep listening after the assistant speaks
# (no second wake word needed). DEFAULT OFF: speaker echo into the mic
# otherwise causes the assistant to converse with itself. Enable only
# with headphones or strong acoustic isolation between speaker and mic.
# WAKE_WORD_FOLLOWUP=1
