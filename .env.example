# Home Assistant MCP
HA_URL=http://localhost:8123
HA_TOKEN=replace_with_long_lived_access_token

# OpenAI
OPENAI_API_KEY=sk-replace-me
OPENAI_MODEL=gpt-5.4-nano

# Memory
MEMORY_DB_PATH=data/assistant.db

# Server timezone — used when the agent calls `schedule_action(goal,
# schedule_kind, schedule_expr)` with a wall-clock once-time or a cron
# expression, and when displaying times back to the user. Set this to
# YOUR local timezone (IANA name) so scheduled actions fire and display correctly.
# Examples: Europe/Madrid, Europe/Moscow, America/Los_Angeles.
# Defaults to the system timezone if unset (UTC inside docker).
TZ=Europe/Madrid

# HTTP API Keys (required). Comma-separated list of Bearer tokens for /audio endpoint.
# Each request to POST /audio must include Authorization: Bearer <key> header.
# Example with multiple keys for different devices:
HTTP_API_KEYS=device1-key,device2-key,smartphone-key

# HTTP Server Port (optional). Default: 3000.
# HTTP_SERVER_PORT=3000

# Telegram (required). The agent has a `send_to_telegram` tool that
# delivers messages to the user via this bot.
# Token from @BotFather; chat_id from @userinfobot or the bot's getUpdates.
TELEGRAM_BOT_TOKEN=replace_with_bot_token
TELEGRAM_CHAT_ID=replace_with_chat_id

# Wake-word (openWakeWord via Python subprocess)
WAKE_WORD_PYTHON=.venv/bin/python
WAKE_WORD_SCRIPT=scripts/wake_word_daemon.py
# Built-in keyword name (hey_jarvis, alexa, hey_mycroft, hey_rhasspy, ok_nabu,
# weatherman, timer) OR a path to a custom .onnx model trained via
# openWakeWord (e.g. models/alisa.onnx).
WAKE_WORD_KEYWORD=hey_jarvis
WAKE_WORD_THRESHOLD=0.5
# Set WAKE_WORD_DEBUG=1 to print per-frame max score and RMS to stderr.
# WAKE_WORD_DEBUG=1
# Set WAKE_WORD_FOLLOWUP=1 to keep listening after the assistant speaks
# (no second wake word needed). DEFAULT OFF: speaker echo into the mic
# otherwise causes the assistant to converse with itself. Enable only
# with headphones or strong acoustic isolation between speaker and mic.
# WAKE_WORD_FOLLOWUP=1

# TTS provider selection (optional). Default: openai.
# Set to "elevenlabs" to use ElevenLabs instead of OpenAI for text-to-speech.
# TTS_PROVIDER=elevenlabs

# ElevenLabs TTS (required when TTS_PROVIDER=elevenlabs).
# Get your key at https://elevenlabs.io — free tier: 10k chars/month.
# ELEVENLABS_API_KEY=replace_with_elevenlabs_key
# Voice ID — find IDs in the ElevenLabs Voice Library. Default: Rachel (21m00Tcm4TlvDq8ikWAM).
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Optional: enable OpenAI's hosted `web_search` tool. When 1, the agent can
# answer "what's the weather in Madrid", "latest news", etc. without a
# dedicated integration. Costs OpenAI tokens per call — leave off if you
# only have HA-backed queries.
# OPENAI_WEB_SEARCH=1

# Monitoring UI auth (Netdata + Dozzle behind Caddy + tinyauth).
# tinyauth serves a real HTML login page and a session cookie; Caddy
# delegates auth checks to it via forward_auth.
#
# These vars are read directly by the tinyauth container via env_file —
# the names must start with TINYAUTH_ (that's what tinyauth itself looks
# for), don't rename them.
#
# TINYAUTH_APPURL: public URL where tinyauth itself is reachable from
# your browser. Used for redirect-back after login and for cookie scope.
# tinyauth requires a hostname with at least 2 labels and rejects raw
# IPs — use mDNS (e.g. http://va.local:8890), a router-side DNS entry
# (http://home.lan:8890), or nip.io (http://192-168-1-42.nip.io:8890).
TINYAUTH_APPURL=http://va.local:8890
# TINYAUTH_AUTH_USERS: comma-separated `username:bcrypthash[:totp_secret]`.
# Generate an entry interactively (also escapes `$` for docker-compose):
#   docker run --rm -it ghcr.io/steveiliop56/tinyauth:v5 user create --interactive --docker
# Or hash a password with any bcrypt tool (cost 10+). Escape every `$` as
# `$$` in this file so docker-compose doesn't try to expand it.
TINYAUTH_AUTH_USERS=admin:replace_with_bcrypt_hash

# EXTERNAL_HEALTHCHECK_URL: optional. If set, netdata's httpcheck collector
# probes this URL once a minute and fires the `httpcheck_external_down`
# alert (Telegram) when probes fail for >2 minutes. Use it to monitor that
# your HA / reverse proxy / DDNS / port forward chain is actually reachable
# from the LAN. Leave empty to disable.
EXTERNAL_HEALTHCHECK_URL=
